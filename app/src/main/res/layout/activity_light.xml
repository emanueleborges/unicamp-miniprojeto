<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/colorBackground">

    <!-- Barra superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorLight"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#212121"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 Sensor de Luz"
            android:textSize="20sp"
            android:textColor="#212121"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Área com conteúdo centralizado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvLuxLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Luminosidade"
            android:textSize="16sp"
            android:textColor="@color/colorTextSecondary"/>

        <TextView
            android:id="@+id/tvLuxValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0 lux"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/colorText"
            android:layout_marginTop="8dp"/>

        <ProgressBar
            android:id="@+id/progressLight"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/colorLight"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvEnvironment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aguardando sensor..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorText"/>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O fundo muda conforme a luz ambiente"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Botão Salvar -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 Salvar Leitura"
        android:textSize="16sp"
        android:textColor="#212121"
        android:backgroundTint="@color/colorLight"
        android:padding="14dp"
        android:layout_margin="16dp"/>
</LinearLayout>
